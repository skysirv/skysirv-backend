{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "moduleDetection": "force",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "types": ["node"]
  },

  "include": [
    "src",
    "scripts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}